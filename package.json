{
  "name": "@maksimdan/admin-kit",
  "version": "0.3.0",
  "description": "Config-driven admin panel kit for Next.js (App Router) + MongoDB with a single env-based admin. Declare entities as field lists; get CRUD routes, forms, tables, and a dashboard for free.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaksimDan/admin-kit.git"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./image": {
      "types": "./src/imageUtils.ts",
      "default": "./src/imageUtils.ts"
    },
    "./mongo": {
      "types": "./src/mongo.ts",
      "default": "./src/mongo.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "template",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "next": ">=15",
    "next-auth": "^4",
    "mongodb": ">=6",
    "zod": ">=3.23",
    "lucide-react": ">=0.4",
    "otplib": ">=12"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "lucide-react": "^0.460.0",
    "mongodb": "^6.11.0",
    "next": "^15.5.19",
    "next-auth": "^4.24.10",
    "otplib": "^12.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  }
}
